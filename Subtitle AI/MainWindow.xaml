<Window x:Class="Subtitle_AI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Subtitle_AI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button x:Name="BtnUploadFile" Content="Upload" HorizontalAlignment="Left" Margin="106,64,0,0" VerticalAlignment="Top" Height="29" Width="61" Command="{Binding ChooseFileCommand}"/>
        <TextBlock x:Name="TxtFilePath" HorizontalAlignment="Left" Margin="187,71,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Text="{Binding FilePath}" Width="213" Height="55"/>
        <ComboBox x:Name="CmbBoxTranslateFrom" HorizontalAlignment="Left" Margin="92,183,0,0" VerticalAlignment="Top" Width="185" ItemsSource="{Binding TargetLanguages}" SelectedItem="{Binding TransFrom}">
        </ComboBox>
        <ComboBox x:Name="CmbBoxTranslateTo" HorizontalAlignment="Left" Margin="377,183,0,0" VerticalAlignment="Top" Width="185" ItemsSource="{Binding TargetLanguages}" SelectedItem="{Binding TransTo}">
         </ComboBox>

    </Grid>
</Window>
